{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qingqiu",
  "version": "0.1.0",
  "identifier": "com.qingqiu.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:7788"
  },
  "app": {
    "windows": [
      {
        "title": "清秋 · qingqiu",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "清秋 · qingqiu"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "qingqiu 桌面壳",
    "longDescription": "qingqiu 是中文 AI 个人助理（命令+v1.0 MVP）。桌面壳集成系统托盘 + FastAPI 网页。"
  }
}